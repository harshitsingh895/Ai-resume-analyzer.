    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze the following resume and provide detailed, constructive feedback.\n\nResume:\n{{ $json.text }}",
        "options": {
          "systemMessage": "You are an expert resume reviewer and career coach. Given the raw text of a resume, produce a well-structured analysis in Markdown format. Include: 1) an overall summary, 2) strengths, 3) areas for improvement, 4) missing keywords/skills for common ATS systems, and 5) a suggested action plan. Use Markdown headings, bullet points, and bold text."
        }
      },
