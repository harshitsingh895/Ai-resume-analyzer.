      "position": [
        800,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const bodyHtml = $input.first().json.data;\nconst html = `\n<html>\n  <head>\n    <meta charset=\"utf-8\" />\n    <style>\n      body { font-family: Arial, Helvetica, sans-serif; color: #222; padding: 40px; line-height: 1.5; }\n      h1, h2, h3 { color: #1a1a1a; }\n      h1 { border-bottom: 2px solid #4a4a4a; padding-bottom: 8px; }\n      ul { margin: 8px 0; padding-left: 24px; }\n      code { background: #f4f4f4; padding: 2px 4px; border-radius: 4px; }\n    </style>\n  </head>\n  <body>${bodyHtml}</body>\n</html>`;\n\nreturn [{ json: { html } }];"
      },
      "id": "8d9d987d-2888-49e1-940a-441cf2d62cfc",
